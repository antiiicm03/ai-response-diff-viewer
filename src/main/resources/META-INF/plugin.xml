<idea-plugin>
    <id>com.github.antiiicm03.airesponsediffviewer</id>
    <name>AI Response Diff Viewer</name>
    <vendor>antiiicm03</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                factoryClass="com.github.antiiicm03.airesponsediffviewer.toolWindow.AiDiffToolWindowFactory"
                id="AI Diff Viewer"
                anchor="bottom"
                icon="AllIcons.Actions.Diff"/>
    </extensions>
</idea-plugin>